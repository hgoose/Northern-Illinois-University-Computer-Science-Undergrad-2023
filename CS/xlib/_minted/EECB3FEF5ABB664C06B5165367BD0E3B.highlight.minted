\PYG{c+cp}{\PYGZsh{}}\PYG{c+cp}{define PResizeInc      (1L \PYGZlt{}\PYGZlt{} 6)       }\PYG{c+cm}{/* program specified resize increments */}
\PYG{c+cp}{\PYGZsh{}}\PYG{c+cp}{define PAspect         (1L \PYGZlt{}\PYGZlt{} 7)       }\PYG{c+cm}{/* program specified min and max aspect ratios */}
\PYG{c+cp}{\PYGZsh{}}\PYG{c+cp}{define PBaseSize       (1L \PYGZlt{}\PYGZlt{} 8)}
\PYG{c+cp}{\PYGZsh{}}\PYG{c+cp}{define PWinGravity     (1L \PYGZlt{}\PYGZlt{} 9)}
