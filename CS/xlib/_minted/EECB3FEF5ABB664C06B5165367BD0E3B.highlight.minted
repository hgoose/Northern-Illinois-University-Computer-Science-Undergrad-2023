\PYG{c+cp}{\PYGZsh{}}\PYG{c+cp}{define USSize          (1L \PYGZlt{}\PYGZlt{} 1)       }\PYG{c+cm}{/* user specified width, height */}
\PYG{c+cp}{\PYGZsh{}}\PYG{c+cp}{define PPosition       (1L \PYGZlt{}\PYGZlt{} 2)       }\PYG{c+cm}{/* program specified position */}
\PYG{c+cp}{\PYGZsh{}}\PYG{c+cp}{define PSize           (1L \PYGZlt{}\PYGZlt{} 3)       }\PYG{c+cm}{/* program specified size */}
\PYG{c+cp}{\PYGZsh{}}\PYG{c+cp}{define PMinSize        (1L \PYGZlt{}\PYGZlt{} 4)       }\PYG{c+cm}{/* program specified minimum size */}
