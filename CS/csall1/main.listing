                        std::vector<int> final;
                        std::vector<int> vec{100, 432, 101, 612, 102, 103, 104, 101, 611, 102, 103, 104, 101, 610, 102, 103, 104, 101, 609, 102, 105};

                        size_t page_size = 100; for (auto& i : vec) { i = i/page_size; }
                        size_t t = 1; int last = vec[0]; final.push_back(last);
                        while (t < vec.size()) {
                            size_t tt = t+1; while (tt < vec.size() && vec[tt] == last) ++tt;

                            if (tt == vec.size()) break;

                            final.push_back(vec[tt]);
                            t = tt;
                            last = vec[t];
                    }
