                    void resume(coroutine_frame* f) {
                        switch (f->state) {
                            case 0:
                            f->x = 1;
                            f->state = 1;
                            yield(f->x);
                            return;

                            case 1:
                            f->x++;
                            f->state = 2;
                            yield(f->x);
                            return;

                            case 2:
                            destroy(f);
                            return;
                        }
                    }
