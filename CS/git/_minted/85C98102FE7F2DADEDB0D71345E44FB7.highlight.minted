\begin{MintedVerbatim}[commandchars=\\\{\},codes={\catcode`\$=3\catcode`\^=7\catcode`\_=8\relax}]
git\PYG{+w}{ }reset\PYG{+w}{ }\PYGZhy{}\PYGZhy{}hard\PYG{+w}{ }HEAD\PYGZti{}3\PYG{+w}{ }\PYG{c+c1}{\PYGZsh{} Go back in time, throwing away changes}

git\PYG{+w}{ }reset\PYG{+w}{ }\PYGZhy{}\PYGZhy{}soft\PYG{+w}{ }HEAD\PYGZti{}3\PYG{+w}{ }\PYG{c+c1}{\PYGZsh{} Set HEAD to point to an earlier commit}
git\PYG{+w}{ }reset\PYG{+w}{ }\PYGZhy{}\PYGZhy{}hard\PYG{+w}{ }\PYG{c+c1}{\PYGZsh{} Wipe out differences in the working tree}
